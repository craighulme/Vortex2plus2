{
  "name": "Vortex Web",
  "version": "0.4.4",
  "manifest_version": 3,
  "description": "Unofficial Vortex browser client with native multiplayer relay support and web-first enhancements.",
  "icons": {
    "16": "img/icon/16.png",
    "32": "img/icon/32.png",
    "48": "img/icon/48.png",
    "128": "img/icon/128.png"
  },
  "host_permissions": [
    "https://playvortex.io/*",
    "https://vortex.towerstats.com/*",
    "https://v22.irongiant.vip/*",
    "https://raw.githubusercontent.com/craighulme/Vortex-Web/*",
    "https://api.github.com/repos/craighulme/Vortex-Web/*",
    "https://raw.githubusercontent.com/craighulme/Vortex2plus2/*",
    "https://api.github.com/repos/craighulme/Vortex2plus2/*"
  ],
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "scripting",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://playvortex.io/*",
        "https://vortex.towerstats.com/*"
      ],
      "css": [
        "styles/main.css"
      ],
      "js": [
        "js/inject/InjectMapLoader.js",
        "js/features/fetchCSPBypass.js",
        "js/features/ProfileCosmetics.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://playvortex.io/search*",
        "https://vortex.towerstats.com/search*"
      ],
      "js": [
        "js/features/Search.js"
      ]
    },
    {
      "matches": [
        "https://playvortex.io/*",
        "https://vortex.towerstats.com/*"
      ],
      "js": [
        "js/features/VortexWebCosmetics.js",
        "js/webVortexLoader.js",
        "js/lightMode.js",
        "js/features/UpdateNotifier.js",
        "js/features/PlayInBrowserButton.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "js/features/MapLoader.js",
        "overrides/*",
        "overrides/v22-runtime/*",
        "overrides/libs/*",
        "img/*",
        "img/textures/*",
        "img/games/website/icons/*",
        "img/games/website/banners/*",
        "files/*",
        "files/meshes/*",
        "files/sounds/*",
        "files/mapdata/*"
      ],
      "matches": [
        "https://playvortex.io/*",
        "https://vortex.towerstats.com/*"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
